{
  "name": "zeromatch",
  "version": "1.0.0",
  "description": "Blazing-fast, picomatch-compatible glob matching, powered by a linear-time Rust bytecode VM.",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/orielhayes/zeromatch.git"
  },
  "license": "MIT",
  "keywords": [
    "zeromatch",
    "glob",
    "matcher"
  ],
  "files": [
    "index.d.ts",
    "index.js"
  ],
  "napi": {
    "binaryName": "zeromatch",
    "targets": [
      "x86_64-pc-windows-msvc"
    ]
  },
  "engines": {
    "node": ">= 18.17.0 < 19 || >= 20.3.0 < 21 || >= 21.1.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "bench": "node --import @oxc-node/core/register benchmark/bench.ts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "format": "run-p format:biome format:rs format:toml",
    "format:biome": "biome format --write .",
    "format:toml": "taplo format",
    "format:rs": "cargo fmt",
    "lint": "biome check .",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "ava",
    "preversion": "napi build --platform && git add .",
    "version": "napi version",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@emnapi/core": "^1.5.0",
    "@emnapi/runtime": "^1.5.0",
    "@napi-rs/cli": "^3.7.0",
    "@oxc-node/core": "^0.1.0",
    "@taplo/cli": "^0.7.0",
    "@tybys/wasm-util": "^0.10.0",
    "ava": "^8.0.0",
    "chalk": "^5.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.0",
    "npm-run-all2": "^9.0.0",
    "tinybench": "^6.0.0",
    "typescript": "^6.0.0"
  },
  "ava": {
    "extensions": [
      "ts"
    ],
    "timeout": "2m",
    "workerThreads": false,
    "environmentVariables": {
      "OXC_TSCONFIG_PATH": "./__test__/tsconfig.json"
    },
    "nodeArguments": [
      "--import",
      "@oxc-node/core/register"
    ]
  }
}
