{
  "name": "zeromatch",
  "version": "1.0.0",
  "description": "Blazing-fast, picomatch-compatible glob matching, powered by a linear-time Rust bytecode VM.",
  "main": "index.js",
  "types": "index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/orielhayes/zeromatch.git"
  },
  "license": "MIT",
  "keywords": [
    "zeromatch",
    "glob",
    "matcher",
    "picomatch",
    "rust",
    "napi"
  ],
  "files": [
    "index.d.ts",
    "index.js"
  ],
  "napi": {
    "binaryName": "zeromatch",
    "targets": [
      "x86_64-pc-windows-msvc"
    ]
  },
  "engines": {
    "node": ">= 20.0.0",
    "bun": ">= 1.1.0"
  },
  "packageManager": "bun@1.3.14",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "bench": "bun run benchmark/bench.ts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "format": "biome format --write . && cargo fmt && taplo format",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepublishOnly": "napi prepublish -t npm",
    "preversion": "napi build --platform && git add .",
    "version": "napi version",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@napi-rs/cli": "^3.7.0",
    "@taplo/cli": "^0.7.0",
    "@types/bun": "^1.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.0",
    "tinybench": "^6.0.0",
    "typescript": "^6.0.0"
  },
  "lint-staged": {
    "*.{js,ts,json}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.rs": [
      "cargo fmt --"
    ],
    "*.toml": [
      "taplo format"
    ]
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "@napi-rs/cli"
  ]
}
